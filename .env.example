# ============================================
# ShieldBox.io — 환경 변수 템플릿
# [위치] 프로젝트 루트 (/)
#
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
#
# VITE_ 접두사 → Vite(프론트엔드)가 읽는 변수
# 그 외        → Node.js(서버)가 읽는 변수
# ============================================

# ── 프론트엔드 ──────────────────────────────
# 백엔드 서버 주소 (소켓 연결에 사용)
# 로컬: http://localhost:4000
# 배포: https://your-service.koyeb.app
VITE_BACKEND_URL=

# ── 서버 ────────────────────────────────────
# 서버 포트 (Koyeb 배포 시 자동 주입됨 — 로컬에서만 사용)
PORT=4000

# 허용할 프론트엔드 주소 (CORS)
# 로컬: http://localhost:5173
# 배포: https://your-app.vercel.app
FRONTEND_URL=

